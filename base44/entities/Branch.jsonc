{
  "name": "Branch",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Branch name"
    },
    "address": {
      "type": "string",
      "description": "Branch address"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone number"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "name"
  ]
}
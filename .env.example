# Supabase frontend-safe public values (placeholder only)
# Use real values in local .env.local later.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only secret. Never expose to frontend code.
# Never commit real service role key values.
SUPABASE_SERVICE_ROLE_KEY=

# App environment flags for safe local demo transition
VITE_APP_ENV=local
VITE_ENABLE_DEMO_MODE=true
VITE_PUBLIC_APP_NAME=Young's Learners

# Local-only RLS smoke test passwords (fake users only).
# Prefer role-specific values, or set one shared fallback via RLS_TEST_PASSWORD.
# Never commit real passwords. Keep real values in .env.local only.
RLS_TEST_PASSWORD=
RLS_TEST_HQ_PASSWORD=
RLS_TEST_SUPERVISOR_PASSWORD=
RLS_TEST_TEACHER_PASSWORD=
RLS_TEST_PARENT_PASSWORD=
RLS_TEST_STUDENT_PASSWORD=

# Notes:
# - VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are frontend-safe public values.
# - SUPABASE_SERVICE_ROLE_KEY must never be sent to the browser.
# - Do not commit real keys.
# - Create .env.local locally and keep it uncommitted.
# Example environment file for future local development.
# Copy to .env.local when real values are available.
# Do not commit real secrets or project-specific credentials.

# Frontend-safe public Supabase values.
# These are exposed to browser code by Vite because they use the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase service role key.
# Never expose this value to frontend code, Vite variables, browser bundles, logs, or public docs.
SUPABASE_SERVICE_ROLE_KEY=

# App configuration for future local/staging/production behavior.
VITE_APP_ENV=local
VITE_ENABLE_DEMO_MODE=true
VITE_PUBLIC_APP_NAME=Young's Learners

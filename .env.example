# Frontend-safe public values (placeholders only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service role key is server-only and must never be exposed to frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# App environment flags for safe local demo transition.
VITE_APP_ENV=local
VITE_ENABLE_DEMO_MODE=true
VITE_PUBLIC_APP_NAME=Young's Learners

# Local-only fake-user passwords for RLS smoke testing.
RLS_TEST_PASSWORD=
RLS_TEST_HQ_PASSWORD=
RLS_TEST_SUPERVISOR_PASSWORD=
RLS_TEST_TEACHER_PASSWORD=
RLS_TEST_PARENT_PASSWORD=
RLS_TEST_STUDENT_PASSWORD=

# Optional explicit fake/dev fixture IDs for deployed AI homework regression.
AI_HOMEWORK_TEST_SUBMISSION_ID=
AI_HOMEWORK_TEST_TASK_ID=
AI_HOMEWORK_TEST_STUDENT_ID=
AI_HOMEWORK_TEST_CLASS_ID=

# Real values go in .env.local only.
# .env.local must not be committed.

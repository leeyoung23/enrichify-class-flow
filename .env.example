# Supabase client env (required for smoke tests using anon + JWT)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional service key for backend-only tooling (never use in frontend runtime)
SUPABASE_SERVICE_ROLE_KEY=

# Shared fallback password used by smoke scripts when role-specific passwords are not set
RLS_TEST_PASSWORD=

# Role-specific smoke test passwords (recommended to set explicitly)
RLS_TEST_HQ_PASSWORD=
RLS_TEST_SUPERVISOR_PASSWORD=
RLS_TEST_TEACHER_PASSWORD=
RLS_TEST_PARENT_PASSWORD=
RLS_TEST_STUDENT_PASSWORD=

# Optional role-specific emails (defaults are used if unset)
RLS_TEST_HQ_EMAIL=hq.demo@example.test
RLS_TEST_SUPERVISOR_EMAIL=supervisor.demo@example.test
RLS_TEST_TEACHER_EMAIL=teacher.demo@example.test
RLS_TEST_PARENT_EMAIL=parent.demo@example.test
RLS_TEST_STUDENT_EMAIL=student.demo@example.test

# Optional unrelated-role checks used by some RLS smokes
RLS_TEST_UNRELATED_PARENT_EMAIL=
RLS_TEST_UNRELATED_PARENT_PASSWORD=

# Optional homework AI fixture IDs used by dedicated AI homework scripts
AI_HOMEWORK_TEST_SUBMISSION_ID=
AI_HOMEWORK_TEST_TASK_ID=
AI_HOMEWORK_TEST_STUDENT_ID=
AI_HOMEWORK_TEST_CLASS_ID=
# Copy to project-root `.env.local` for real values. `.env.local` is gitignored — do not commit secrets.
# Do not use a VITE_ prefix for server-only / script-only variables (see AI Parent Report block below).

# Frontend-safe public values (placeholders only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service role key is server-only and must never be exposed to frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# App environment flags for safe local demo transition.
VITE_APP_ENV=local
VITE_ENABLE_DEMO_MODE=true
VITE_PUBLIC_APP_NAME=Young's Learners

# Local-only fake-user passwords for RLS smoke testing.
RLS_TEST_PASSWORD=
RLS_TEST_HQ_PASSWORD=
RLS_TEST_SUPERVISOR_PASSWORD=
RLS_TEST_TEACHER_PASSWORD=
RLS_TEST_PARENT_PASSWORD=
RLS_TEST_STUDENT_PASSWORD=
RLS_TEST_HQ_EMAIL=
RLS_TEST_STUDENT_EMAIL=
RLS_TEST_UNRELATED_PARENT_EMAIL=
RLS_TEST_UNRELATED_PARENT_PASSWORD=

# Optional fake/dev announcement smoke fixture for cross-branch negative check.
ANNOUNCEMENTS_TEST_OTHER_BRANCH_ID=

# Optional fake/dev parent-announcements smoke fixtures.
PARENT_ANNOUNCEMENTS_TEST_BRANCH_ID=
PARENT_ANNOUNCEMENTS_TEST_CLASS_ID=
PARENT_ANNOUNCEMENTS_TEST_STUDENT_ID=
PARENT_ANNOUNCEMENTS_TEST_OTHER_BRANCH_ID=
PARENT_ANNOUNCEMENTS_TEST_PARENT_EMAIL=
PARENT_ANNOUNCEMENTS_TEST_UNRELATED_PARENT_EMAIL=

# Optional explicit fake/dev fixture IDs for deployed AI homework regression.
AI_HOMEWORK_TEST_SUBMISSION_ID=
AI_HOMEWORK_TEST_TASK_ID=
AI_HOMEWORK_TEST_STUDENT_ID=
AI_HOMEWORK_TEST_CLASS_ID=

# Edge Function provider adapter mode for homework AI draft generation.
# Allowed: disabled | mock | future_real_provider_placeholder
AI_HOMEWORK_PROVIDER_MODE=disabled

# --- AI Parent Report — real provider smoke (server / Node scripts only; same names as Supabase Edge secrets) ---
# Do NOT use VITE_ prefix: never expose these to the browser bundle.
# API key must come from the provider's developer/API keys area (e.g. OpenAI api-keys) — not a ChatGPT web login, passkey, or PIN.
# Required for `npm run test:ai-parent-report:real-provider-smoke` to PASS. Leave empty for CHECK-skip (not a failure).
AI_PARENT_REPORT_PROVIDER_API_KEY=
AI_PARENT_REPORT_PROVIDER_MODEL=
# Optional OpenAI-compatible API base (defaults in code if unset).
AI_PARENT_REPORT_PROVIDER_BASE_URL=

# Real values go in .env.local only.
# .env.local must not be committed.

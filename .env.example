# Example environment file for future local development.
# Copy to .env.local when real values are available.
# Do not commit real secrets or project-specific credentials.

# Frontend-safe public Supabase values.
# These are exposed to browser code by Vite because they use the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase service role key.
# Never expose this value to frontend code, Vite variables, browser bundles, logs, or public docs.
SUPABASE_SERVICE_ROLE_KEY=

# App configuration for future local/staging/production behavior.
VITE_APP_ENV=local
VITE_ENABLE_DEMO_MODE=true
VITE_PUBLIC_APP_NAME=Young's Learners
